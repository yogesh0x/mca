# =========================
# Universal project config
# =========================

# Dataset directory (contains 9 class folders)
# Example:
# DATASET_PATH=./data/dataset
DATASET_PATH=./data/dataset

# Trained model file (.keras)
# Example:
# MODEL_PATH=./models/efficientnetb2_80plus.keras
MODEL_PATH=./models/efficientnetb2_80plus.keras

# Output folder for verification artifacts
# Example:
# RESULTS_DIR=./Results
RESULTS_DIR=./Results

# Optional tuning
BATCH_SIZE=16
TARGET_COUNT=500
MODEL_NAME=efficientnetb2_80plus.keras
SEED=42
